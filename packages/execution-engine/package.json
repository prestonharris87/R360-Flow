    "@r360/db": "workspace:*",
    "@r360/json-translator": "workspace:*",
    "n8n-workflow": "2.11.0",
    "n8n-core": "2.11.0",
    "n8n-nodes-base": "2.11.0",
    "@n8n/di": "0.10.0",
    "@n8n/config": "2.10.0",
    "@n8n/backend-common": "1.11.0",
    "@n8n/errors": "0.6.0",
    "@n8n/constants": "0.19.0",
    "@n8n/decorators": "1.11.0",
    "reflect-metadata": "^0.2.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
