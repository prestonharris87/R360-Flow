    "@r360/execution-engine": "workspace:*",
    "@r360/json-translator": "workspace:*",
    "n8n-workflow": "2.11.0",
    "drizzle-orm": "^0.33.0",
    "fastify": "^5.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "jose": "^5.6.0",
    "zod": "^3.23.0",
    "ioredis": "^5.4.0",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "tsx": "^4.16.0"
  }
