# R360 Flow — Environment Variables
# Copy to .env and adjust as needed: cp .env.example .env

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://r360:r360_dev_password@localhost:5432/r360flow
DATABASE_POOL_MAX=10

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API Server ───────────────────────────────────────────────────────
PORT=3100
NODE_ENV=development

# ── Auth ─────────────────────────────────────────────────────────────
# Admin API key for tenant management endpoints
ADMIN_API_KEY=dev-admin-key

# JWT secret for signing tokens (dev only — use a real secret in production)
JWT_SECRET=dev-jwt-secret-change-in-production

# ── Encryption ───────────────────────────────────────────────────────
# AES-256 key for credential encryption (32 bytes, hex-encoded)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ── Stripe (optional) ───────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Frontend ─────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3100/api
